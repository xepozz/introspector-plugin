<idea-plugin>
    <depends optional="true" config-file="kotlin-exec.xml">org.jetbrains.kotlin</depends>
    <depends optional="true" config-file="java-introspect.xml">com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.UiInspectorToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.ScreenshotToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.ArchitectureToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.PsiToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.HealthToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.EditorToolset"/>
        <mcpServer.mcpToolset implementation="com.github.xepozz.ide.introspector.tools.LogToolset"/>
    </extensions>
</idea-plugin>
