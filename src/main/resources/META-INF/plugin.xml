<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.xepozz.introspectorplugin</id>
    <name>IDE Introspect MCP</name>
    <vendor>xepozz</vendor>
    <description><![CDATA[
        <p><b>IDE Introspect MCP</b> exposes the running IntelliJ IDE to MCP clients (Claude, Cursor, Codex, ...) so an agent can:</p>
        <ul>
            <li>Read the Swing UI tree, find components by name/coordinates/XPath, capture screenshots</li>
            <li>Enumerate plugins and extension points live from this very IDE instance</li>
            <li>Execute arbitrary Kotlin in the IDE JVM (opt-in, per-call confirmation)</li>
        </ul>
        <p>Ships with a Platform Explorer tool window for interactive plugin-architecture browsing without an MCP client.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <depends optional="true" config-file="mcp-integration.xml">com.intellij.mcpServer</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Platform Explorer"
                    anchor="right"
                    icon="AllIcons.Nodes.Plugin"
                    factoryClass="com.github.xepozz.introspectorplugin.toolwindow.PlatformExplorerToolWindowFactory"/>

        <applicationService
            serviceImplementation="com.github.xepozz.introspectorplugin.core.ComponentRegistry"/>
        <applicationService
            serviceImplementation="com.github.xepozz.introspectorplugin.core.PluginInventory"/>
        <applicationService
            serviceImplementation="com.github.xepozz.introspectorplugin.exec.ExecSettings"/>

        <applicationConfigurable
            instance="com.github.xepozz.introspectorplugin.exec.ExecSettingsConfigurable"
            id="com.github.xepozz.introspectorplugin.exec.settings"
            displayName="IDE Introspect MCP"
            parentId="tools"/>
    </extensions>
</idea-plugin>
